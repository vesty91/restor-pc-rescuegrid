# Restor-PC RescueGrid — Configuration v12.3

# === BACKEND / DASHBOARD ===

# URL de la base de données (SQLite par défaut, PostgreSQL pour production)
DATABASE_URL="sqlite:///./rescuegrid.db"
# Pour PostgreSQL (Synology) :
# DATABASE_URL="postgresql://rescuegrid:rescuegrid2026@postgres:5432/rescuegrid"

# Port du serveur dashboard
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# === AUTHENTIFICATION ===

# Clé secrète JWT (CHANGER EN PRODUCTION)
SECRET_KEY="change-me-in-production-2026"

# Mot de passe admin par défaut (CHANGER EN PRODUCTION)
ADMIN_PASSWORD="rescuegrid2026"

# Anti brute-force sur /login (valeurs par défaut raisonnables, décommenter pour ajuster)
# LOGIN_RATE_LIMIT_COUNT=5            # tentatives max par IP avant blocage temporaire
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=300 # fenêtre glissante (secondes) pour le rate limit IP
# ACCOUNT_LOCKOUT_COUNT=5             # tentatives max par compte (toutes IP confondues) avant verrouillage
# ACCOUNT_LOCKOUT_WINDOW_SECONDS=900  # durée de la fenêtre de verrouillage compte (secondes)

# Durée de session (minutes)
TOKEN_EXPIRE_MINUTES=480

# === AGENT WINDOWS ===

# Dossier racine de sauvegarde par défaut
BACKUP_ROOT="E:\RestorPC"

# Upload automatique vers le dashboard
# Décommenter pour activer :
# DASHBOARD_UPLOAD_URL="http://localhost:8000/upload"

# === STOCKAGE ===

# Dossier de stockage local (montage NAS possible)
STORAGE_PATH="./storage"

# === SAUVEGARDE PLANIFIEE (base de donnees dashboard) ===
# Copie automatique quotidienne de la base (SQLite : copie fichier, PostgreSQL :
# pg_dump) dans STORAGE_PATH/backups, avec rotation. Voir /tools > "Historique
# des sauvegardes planifiees" et docs/BACKUP_PLANIFIE.md.
# BACKUP_SCHEDULE_ENABLED=true    # false pour desactiver le scheduler interne
# BACKUP_SCHEDULE_HOUR=3          # heure UTC de declenchement quotidien (0-23)
# BACKUP_RETENTION_COUNT=14       # nombre de sauvegardes conservees avant rotation

# === DOCKER / SYNOLOGY ===

# PostgreSQL
POSTGRES_USER=rescuegrid
POSTGRES_PASSWORD=rescuegrid2026
POSTGRES_DB=rescuegrid

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=rescuegrid2026

# pgAdmin
PGADMIN_EMAIL=admin@rescuegrid.local
PGADMIN_PASSWORD=rescuegrid2026

# Version de l'image Docker
IMAGE_TAG="restorpc-rescuegrid:latest"

# === LIMITES DE SECURITE UPLOAD ===

# Cle API pour l'upload ZIP depuis l'agent (recommande en production, requise hors session)
# UPLOAD_API_KEY="change-me-upload-key"
# Par defaut, sans UPLOAD_API_KEY, l'upload anonyme est REFUSE (secure by default).
# Pour un usage local/dev sans cle (agent sur le meme poste, reseau de confiance),
# decommenter la ligne suivante :
# ALLOW_ANONYMOUS_UPLOAD=true

# 2 Go par archive ZIP importee
MAX_UPLOAD_BYTES=2147483648
# 4 Go decompression totale maximum
MAX_ZIP_UNCOMPRESSED_BYTES=4294967296
MAX_ZIP_FILES=10000

# === RESTOR-PC — INFORMATIONS ENTREPRISE (AUTO-ENTREPRENEUR) ===

RESTORPC_COMPANY_NAME=RESTOR-PC
RESTORPC_COMPANY_SUBTITLE=Dépannage informatique - Diagnostic & récupération de données
RESTORPC_COMPANY_ADDRESS=3 rue Auber\n91330 Yerres
RESTORPC_COMPANY_PHONE=07 67 28 23 65
RESTORPC_COMPANY_EMAIL=contact@restor-pc.fr
RESTORPC_COMPANY_SITE=www.restor-pc.fr
RESTORPC_COMPANY_SIRET=SIRET : non renseigné
RESTORPC_COMPANY_VAT=TVA non applicable, article 293 B du CGI
RESTORPC_PAYMENT_TERMS=Montant à régler à réception, en espèces ou par virement immédiat. Paiement par carte bancaire / TPE non disponible. RIB / IBAN : à compléter avant envoi si règlement par virement.
RESTORPC_LEGAL_TEXT=TVA non applicable, article 293 B du Code Général des Impôts. Merci pour votre confiance.

# === ENVOI EMAIL DEVIS / FACTURES (SMTP Infomaniak) ===
# Si MAIL_ENABLED=false ou si MAIL_PASSWORD/SMTP_PASSWORD est vide, l'envoi
# direct est désactivé (le PDF reste téléchargeable manuellement).
# Les deux jeux de variables (MAIL_* et SMTP_*) sont acceptés par compatibilité ;
# ne renseigner qu'un seul jeu suffit, MAIL_* est prioritaire.

MAIL_ENABLED=true
MAIL_PROVIDER=infomaniak
MAIL_SERVER=mail.infomaniak.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=contact@restor-pc.fr
MAIL_PASSWORD="A_REMPLACER_PAR_LE_MOT_DE_PASSE_INFOMANIAK"
MAIL_DEFAULT_SENDER=contact@restor-pc.fr
MAIL_FROM_NAME="RESTOR-PC"

# Compatibilité anciens noms SMTP_* utilisés par certaines routes historiques
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=contact@restor-pc.fr
SMTP_PASSWORD="A_REMPLACER_PAR_LE_MOT_DE_PASSE_INFOMANIAK"
SMTP_SENDER=contact@restor-pc.fr
SMTP_TLS=true
SMTP_SSL=false

# === ESPACE CLIENT — CONNEXION OAUTH GOOGLE / GITHUB ===
# Optionnel : si ces variables ne sont pas renseignées, les boutons "Se connecter
# avec Google/GitHub" sont automatiquement masqués sur /client/login (le mot de
# passe reste toujours disponible). L'email retourné par le provider doit déjà
# correspondre à un ClientAccount créé par l'atelier (voir fiche client admin) :
# aucune création de compte à la volée par un inconnu n'est autorisée.
#
# URL de callback à enregistrer côté Google Cloud Console / GitHub OAuth Apps :
#   <OAUTH_REDIRECT_BASE_URL>/client/auth/google/callback
#   <OAUTH_REDIRECT_BASE_URL>/client/auth/github/callback
# OAUTH_REDIRECT_BASE_URL="https://votre-domaine.fr"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# === ESPACE CLIENT — SESSION ET SECURITE ===
# CLIENT_TOKEN_EXPIRE_MINUTES=1440             # durée de session client (24h par défaut)
# CLIENT_LOGIN_RATE_LIMIT_COUNT=5              # tentatives max par IP avant blocage temporaire
# CLIENT_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300   # fenêtre glissante (secondes) pour le rate limit IP
# CLIENT_ACCOUNT_LOCKOUT_COUNT=5               # tentatives max par compte avant verrouillage
# CLIENT_ACCOUNT_LOCKOUT_WINDOW_SECONDS=900    # durée de la fenêtre de verrouillage compte (secondes)
